{
  "title": "🪣 S3 Bucket Monitoring",
  "tags": ["s3", "storage", "devops"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 36,
  "panels": [
    {
      "type": "stat",
      "title": "Total Cluster Size",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(s3_bucket_size_bytes)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Total Objects",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(s3_bucket_objects_total)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "table",
      "title": "Bucket Details & Limits Overview",
      "description": "Highlights buckets that exceed 100GB or haven't been modified in 3 days.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "s3_bucket_size_bytes",
          "format": "table",
          "instant": true,
          "refId": "Size"
        },
        {
          "expr": "s3_bucket_objects_total",
          "format": "table",
          "instant": true,
          "refId": "Objects"
        },
        {
          "expr": "time() - s3_bucket_last_modified_timestamp_seconds",
          "format": "table",
          "instant": true,
          "refId": "Age"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "bucket",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true
            },
            "indexByName": {
              "bucket": 0,
              "Value #Size": 1,
              "Value #Objects": 2,
              "Value #Age": 3
            },
            "renameByName": {
              "Value #Size": "Size",
              "Value #Objects": "Objects",
              "Value #Age": "Time Since Modified"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Size" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "red", "value": 107374182400 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Objects" },
            "properties": [
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time Since Modified" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "red", "value": 259200 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Size"
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  }
}
